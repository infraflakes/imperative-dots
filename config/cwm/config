unbind-key all
unbind-mouse all

fontname "JetBrainsMono:pixelsize=13:bold"
borderwidth 3

color activeborder   "#86afef"
color menubg "#1e1b25"     # Deep dark background canvas
color menufg "#86afef"     # Normal unselected text (White/Storm)
color font "#c0caf5"       # General font rendering base color
color selfont "#1e1b25"    # Flipped text color for selected items (Dark text)

ignore lemonbar

sticky yes # New windows automatically join current workspace

bind-key XF86AudioRaiseVolume "pactl set-sink-volume @DEFAULT_SINK@ +2%"
bind-key XF86AudioLowerVolume "pactl set-sink-volume @DEFAULT_SINK@ -2%"
bind-key XF86AudioMute "pactl set-sink-mute @DEFAULT_SINK@ toggle"
bind-key XF86MonBrightnessUp "light -A 5"
bind-key XF86MonBrightnessDown "light -U 5"

bind-key 4-Return    "kitty --single-instance"
bind-key 4-l     "slock"
bind-key M-space         menu-exec     # Built-in system app path launcher
bind-key 4-slash menu-window

bind-key 4-space menu-cmd
bind-mouse 3 menu-cmd
command terminal   "kitty"
command editor   "kitty -e nvim"
command files      "kitty -e yazi"
command browser    "firefox-bin"
command vesktop    "vesktop-bin"
command monitor    "kitty -e btm"
command screenshot    "flameshot gui"
command "-------------" "true"
command suspend    "suspend.sh"
command reboot     "loginctl reboot"
command shutdown   "loginctl poweroff"

bind-key 4-q         window-close
bind-key M-Tab window-cycle

bind-mouse 4-1 window-move
bind-mouse 4-3 window-resize

bind-key 4-Right group-cycle
bind-key 4-Left group-rcycle

bind-key 4S-f        window-fullscreen
bind-key 4-f         window-maximize

bind-key 4-1         group-only-1
bind-key 4-2         group-only-2
bind-key 4-3         group-only-3
bind-key 4-4         group-only-4
bind-key 4-5         group-only-5
bind-key 4-6         group-only-6
bind-key 4-7         group-only-7
bind-key 4-8         group-only-8

bind-key 4S-1        window-movetogroup-1
bind-key 4S-2        window-movetogroup-2
bind-key 4S-3        window-movetogroup-3
bind-key 4S-4        window-movetogroup-4
bind-key 4S-5        window-movetogroup-5
bind-key 4S-6        window-movetogroup-6
bind-key 4S-7        window-movetogroup-7
bind-key 4S-8        window-movetogroup-8

bind-key 4S-r        restart            # Live-reload
bind-key 4-BackSpace        quit               # Clean log-out out of X11 session
